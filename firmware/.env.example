# GrowTower Firmware Environment Variables
# Copy this file to .env and fill in your credentials

# WiFi Credentials
WIFI_SSID=YourWiFiName
WIFI_PASS=YourWiFiPassword

# Notes:
# - OTA only works when WiFi is connected
# - Device must be on the same network as your computer
# - mDNS hostname: growtower.local
# - OTA port: 3232
# 
# OTA Upload Command:
#   pio run -t upload -e main_ota
#
# Or with explicit port:
#   pio run -t upload -e main_ota --upload-port growtower.local
